// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

SUNCLAW_CODE_SIGN_STYLE = Automatic
SUNCLAW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

SUNCLAW_APP_BUNDLE_ID = ai.sunclaw.client
SUNCLAW_SHARE_BUNDLE_ID = ai.sunclaw.client.share
SUNCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.sunclaw.client.activitywidget
SUNCLAW_WATCH_APP_BUNDLE_ID = ai.sunclaw.client.watchkitapp
SUNCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.sunclaw.client.watchkitapp.extension

// Leave empty with automatic signing.
SUNCLAW_APP_PROFILE =
SUNCLAW_SHARE_PROFILE =
SUNCLAW_WATCH_APP_PROFILE =
SUNCLAW_WATCH_EXTENSION_PROFILE =
