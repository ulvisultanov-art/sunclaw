{
  "name": "@sunclaw/diagnostics-otel",
  "version": "2026.6.2",
  "description": "SunClaw diagnostics OpenTelemetry exporter for metrics and traces.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "type": "module",
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.218.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-logs": "0.218.0",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1"
  },
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*"
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@sunclaw/diagnostics-otel",
      "npmSpec": "@sunclaw/diagnostics-otel",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.25"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
