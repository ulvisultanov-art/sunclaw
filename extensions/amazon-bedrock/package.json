{
  "name": "@sunclaw/amazon-bedrock-provider",
  "version": "2026.6.2",
  "description": "SunClaw Amazon Bedrock provider plugin with model discovery, embeddings, and guardrail support.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-bedrock": "3.1056.0",
    "@aws-sdk/client-bedrock-runtime": "3.1056.0",
    "@aws-sdk/credential-provider-node": "3.972.46",
    "@smithy/node-http-handler": "4.7.5",
    "@smithy/shared-ini-file-loader": "4.5.5",
    "@smithy/types": "4.14.2"
  },
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*"
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@sunclaw/amazon-bedrock-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
