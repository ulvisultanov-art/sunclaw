{
  "name": "@sunclaw/google-meet",
  "version": "2026.6.2",
  "description": "SunClaw Google Meet participant plugin for joining calls through Chrome or Twilio transports.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*",
    "sunclaw": "2026.5.28"
  },
  "peerDependencies": {
    "sunclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "sunclaw": {
      "optional": true
    }
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@sunclaw/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
