{
  "name": "@sunclaw/pixverse-provider",
  "version": "2026.6.2",
  "description": "SunClaw PixVerse video generation provider plugin.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "type": "module",
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*",
    "sunclaw": "2026.5.28"
  },
  "peerDependencies": {
    "sunclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "sunclaw": {
      "optional": true
    }
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@sunclaw/pixverse-provider",
      "npmSpec": "@sunclaw/pixverse-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.26"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
