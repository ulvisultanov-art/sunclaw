{
  "name": "@sunclaw/matrix",
  "version": "2026.6.2",
  "description": "SunClaw Matrix channel plugin for rooms and direct messages.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "type": "module",
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-nodejs": "0.6.0",
    "@matrix-org/matrix-sdk-crypto-wasm": "18.3.0",
    "fake-indexeddb": "6.2.5",
    "markdown-it": "14.2.0",
    "matrix-js-sdk": "41.6.0",
    "music-metadata": "11.12.3",
    "typebox": "1.1.39",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*",
    "sunclaw": "2026.5.28"
  },
  "peerDependencies": {
    "sunclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "sunclaw": {
      "optional": true
    }
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "setupFeatures": {
      "configPromotion": true
    },
    "channel": {
      "id": "matrix",
      "label": "Matrix",
      "selectionLabel": "Matrix (plugin)",
      "docsPath": "/channels/matrix",
      "docsLabel": "matrix",
      "blurb": "open protocol; install the plugin to enable.",
      "order": 70,
      "markdownCapable": true,
      "quickstartAllowFrom": true,
      "doctorCapabilities": {
        "dmAllowFromMode": "nestedOnly",
        "groupModel": "sender",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": true
      },
      "cliAddOptions": [
        {
          "flags": "--homeserver <url>",
          "description": "Matrix homeserver URL"
        },
        {
          "flags": "--user-id <id>",
          "description": "Matrix user ID"
        },
        {
          "flags": "--access-token <token>",
          "description": "Matrix access token"
        },
        {
          "flags": "--device-name <name>",
          "description": "Matrix device name"
        },
        {
          "flags": "--initial-sync-limit <n>",
          "description": "Matrix initial sync limit"
        }
      ],
      "persistedAuthState": {
        "specifier": "./auth-presence",
        "exportName": "hasAnyMatrixAuth"
      }
    },
    "install": {
      "clawhubSpec": "clawhub:@sunclaw/matrix",
      "npmSpec": "@sunclaw/matrix",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.4.10",
      "allowInvalidConfigRecovery": true
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
