{
  "name": "@sunclaw/zalouser",
  "version": "2026.6.2",
  "description": "SunClaw Zalo Personal Account plugin via native zca-js integration.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "type": "module",
  "dependencies": {
    "typebox": "1.1.39",
    "zca-js": "2.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*",
    "sunclaw": "2026.5.28"
  },
  "peerDependencies": {
    "sunclaw": ">=2026.6.2"
  },
  "peerDependenciesMeta": {
    "sunclaw": {
      "optional": true
    }
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalouser",
      "label": "Zalo Personal",
      "selectionLabel": "Zalo (Personal Account)",
      "docsPath": "/channels/zalouser",
      "docsLabel": "zalouser",
      "blurb": "Zalo personal account via QR code login.",
      "aliases": [
        "zlu"
      ],
      "order": 85,
      "quickstartAllowFrom": false,
      "doctorCapabilities": {
        "dmAllowFromMode": "topOnly",
        "groupModel": "hybrid",
        "groupAllowFromFallbackToAllowFrom": false,
        "warnOnEmptyGroupSenderAllowlist": false
      }
    },
    "install": {
      "npmSpec": "@sunclaw/zalouser",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
