{
  "name": "@sunclaw/sms",
  "version": "2026.6.2",
  "description": "SunClaw SMS channel plugin for Twilio text messages.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulvisultanov-art/sunclaw"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sunclaw/plugin-sdk": "workspace:*"
  },
  "sunclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "sms",
      "label": "SMS",
      "selectionLabel": "SMS (Twilio)",
      "detailLabel": "Twilio SMS",
      "docsPath": "/channels/sms",
      "docsLabel": "sms",
      "blurb": "Twilio-backed SMS with inbound webhooks and outbound replies.",
      "order": 88,
      "quickstartAllowFrom": true
    },
    "compat": {
      "pluginApi": ">=2026.6.2"
    },
    "build": {
      "sunclawVersion": "2026.6.2"
    }
  }
}
